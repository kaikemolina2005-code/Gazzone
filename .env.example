# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_key_here"
CLERK_SECRET_KEY="sk_test_your_secret_here"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# Ecwid E-commerce Integration
# Get these from https://www.ecwid.com/
ECWID_STORE_ID="your_store_id_here"
ECWID_ACCESS_TOKEN="your_access_token_here"

# Gemini API
# Required for Gemini AI API calls
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
# The URL where this app is hosted
APP_URL="MY_APP_URL"
